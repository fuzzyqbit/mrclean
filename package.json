{
  "name": "mrclean-claude",
  "version": "1.0.0-rc.9",
  "description": "In-session sanitizer for Claude Code that prevents secrets and proprietary terms from reaching Anthropic, MCP servers, or cloud agents. Local, deterministic, no telemetry.",
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fuzzyqbit/mrclean.git"
  },
  "homepage": "https://github.com/fuzzyqbit/mrclean#readme",
  "bugs": {
    "url": "https://github.com/fuzzyqbit/mrclean/issues"
  },
  "keywords": [
    "claude-code",
    "claude",
    "mcp",
    "security",
    "secrets",
    "redaction",
    "sanitizer",
    "hook",
    "anthropic",
    "dlp"
  ],
  "type": "module",
  "engines": {
    "node": ">=20.18.0"
  },
  "bin": {
    "mrclean": "./dist/cli.js",
    "mrclean-mcp": "./dist/mcp.js"
  },
  "main": "./dist/cli.js",
  "files": [
    "dist/cli.js",
    "dist/cli.js.map",
    "dist/cli.d.ts",
    "dist/mcp.js",
    "dist/mcp.js.map",
    "dist/mcp.d.ts",
    "vendor/gitleaks-rules.toml",
    "vendor/gitleaks-rules.toml.sha256",
    "vendor/SKIPPED_GITLEAKS_RULES.md",
    "README.md",
    "LICENSE",
    "THREAT_MODEL.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "vendor:gitleaks": "tsx scripts/vendor-gitleaks.ts",
    "dev:cli": "tsx src/cli.ts",
    "dev:mcp": "tsx src/mcp.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "release": "npm run build && changeset publish --provenance --access public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@secretlint/core": "^13.0.0",
    "@secretlint/node": "^13.0.0",
    "@secretlint/secretlint-rule-preset-recommend": "^13.0.0",
    "commander": "^13.1.0",
    "dotenv": "^17.4.2",
    "fast-glob": "^3.3.3",
    "picocolors": "^1.1.1",
    "smol-toml": "^1.6.1",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "@huggingface/transformers": "^4.2.0",
    "onnxruntime-node": "^1.24.3"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@types/node": "^20.18.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsup": "^8.5.1",
    "tsx": "^4.20.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.6"
  }
}
